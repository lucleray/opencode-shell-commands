{
  "name": "opencode-shell-commands",
  "version": "0.1.0",
  "description": "Run shell commands directly from OpenCode custom commands, skipping the LLM entirely.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "shell",
    "commands"
  ],
  "author": "Luc Leray",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucleray/opencode-shell-commands.git"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "typescript": "^5.0.0"
  }
}
